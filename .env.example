# Copie para .env e ajuste se necessário. .env NÃO é versionado (só este .example).
# Tudo funciona SEM .env — estes são os defaults já embutidos.

# --- Container MySQL (lido pelo docker-compose) ---
MYSQL_DATABASE=motor_cambial
MYSQL_USER=motor
MYSQL_PASSWORD=motor
MYSQL_ROOT_PASSWORD=root

# --- Aplicação (lido por Config, prefixo MOTOR_) ---
# Dentro de um container na rede do compose, use MOTOR_DB_HOST=db.
# Do host (venv), use 127.0.0.1 — os alvos `make migrate`/`make test-integration` já fazem isso.
MOTOR_DB_HOST=127.0.0.1
MOTOR_DB_PORT=3306
MOTOR_DB_USER=motor
MOTOR_DB_PASSWORD=motor
MOTOR_DB_NAME=motor_cambial

# --- Testes de integração ---
MOTOR_TEST_DB_URL=mysql+pymysql://motor:motor@127.0.0.1:3306/motor_cambial
